  document.getElementById('simTotal').textContent=val.toLocaleString('fr-FR')+' FCFA';
  document.getElementById('simComm').textContent='−'+comm.toLocaleString('fr-FR')+' FCFA';
  document.getElementById('simNet').textContent=net.toLocaleString('fr-FR')+' FCFA';
}
function simulatePay(){
  const btn=document.getElementById('simPayBtn');
  btn.disabled=true;
  btn.innerHTML='<span style="display:inline-block;animation:spin .8s linear infinite">⟳</span> Traitement en cours…';
  document.getElementById('simResult').classList.remove('show');
  setTimeout(()=>{
    btn.disabled=false;
    btn.innerHTML='<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="width:18px;height:18px"><rect x="5" y="2" width="14" height="20" rx="2"/><line x1="12" y1="18" x2="12.01" y2="18" stroke-width="3"/></svg> Simuler le paiement Mobile Money';
    const net=MISSIONS[selectedMission].val-Math.round(MISSIONS[selectedMission].val*0.07);
    document.getElementById('simResultMsg').textContent=`${net.toLocaleString('fr-FR')} FCFA transférés sur votre compte ${selectedMM} MoMo avec succès !`;
    document.getElementById('simResult').classList.add('show');
    toast('Paiement simulé avec succès !');
  },2000);
}

// ═══ DASHBOARD ═══════════════════════════════════════════════════════
function initDashboard(){
  // Animate metric counters
  setTimeout(()=>{
    animCount(document.getElementById('metricRevenu'),87500,' FCFA');
    animCount(document.getElementById('metricMissions'),19);
    const noteEl=document.getElementById('metricNote');
    noteEl.textContent='4.9 / 5';
    animCount(document.getElementById('metricVues'),342);
  },200);

  // Bars
  const bars=[
    {label:'Maths terminale',val:80,n:12},
    {label:'Algèbre',val:47,n:7},
    {label:'Statistiques',val:27,n:4},
    {label:'BAC camerounais',val:14,n:2},
  ];
  document.getElementById('dashBars').innerHTML=bars.map(b=>`
    <div class="bar-item">
      <div class="bar-label">${b.label}</div>
      <div class="bar-track"><div class="bar-fill" style="width:0%" data-w="${b.val}%"></div></div>
      <div class="bar-num">${b.n}</div>
    </div>
  `).join('');
  setTimeout(()=>{
    document.querySelectorAll('.bar-fill').forEach(el=>el.style.width=el.dataset.w);
  },300);

  // Activity
  document.getElementById('dashActivity').innerHTML=ACTIVITIES.map(a=>`
    <div class="activity-item">
      <div class="activity-dot"></div>
      <div class="activity-text">${a.text}</div>
      <div class="activity-time">${a.time}</div>
    </div>
  `).join('');
}

// ═══ MESSAGES ════════════════════════════════════════════════════════
function initMessages(){
  const body=document.getElementById('msgBody');
  if(!body||body.children.length>0)return;
  body.innerHTML=MESSAGES_INIT.map(m=>`
    <div class="msg ${m.me?'me':''}">
      ${!m.me?'<div class="msg-avatar">KN</div>':''}
      <div>
        <div class="msg-bubble">${m.text}</div>
        <div class="msg-time">${m.time}</div>
      </div>
    </div>
  `).join('');
  body.scrollTop=body.scrollHeight;
}
function sendMsg(){
  const input=document.getElementById('msgInput');
  const text=input.value.trim();if(!text)return;
  const body=document.getElementById('msgBody');
  const now=new Date();
  const time=now.getHours()+':'+String(now.getMinutes()).padStart(2,'0');
  const el=document.createElement('div');
  el.className='msg me';
  el.innerHTML=`<div><div class="msg-bubble">${text}</div><div class="msg-time">${time}</div></div>`;
  body.appendChild(el);
  input.value='';
  body.scrollTop=body.scrollHeight;
  // Auto-reply
  setTimeout(()=>{
    const replies=["Parfait, c'est noté !","D'accord, je vous confirme ça.","Super, on fait comme ça alors.","Entendu ! Je vous envoie un devis."];
    const r=replies[Math.floor(Math.random()*replies.length)];
    const el2=document.createElement('div');
    el2.className='msg';
    el2.innerHTML=`<div class="msg-avatar">KN</div><div><div class="msg-bubble">${r}</div><div class="msg-time">${time}</div></div>`;
    body.appendChild(el2);
    body.scrollTop=body.scrollHeight;
  },1800);
}

// ═══ TESTIMONIALS ════════════════════════════════════════════════════
function initTestimonials(){
  const doubled=[...TESTIMONIALS,...TESTIMONIALS];
  document.getElementById('testiTrack').innerHTML=doubled.map(t=>`
    <div class="testi-card">
      <div class="testi-stars">${[1,2,3,4,5].map(()=>'<svg viewBox="0 0 24 24"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>').join('')}</div>
      <p class="testi-text">"${t.text}"</p>
      <div class="testi-author">
        <div class="testi-av">${t.av}</div>
        <div><div class="testi-name">${t.name}</div><div class="testi-role">${t.role}</div></div>
      </div>
    </div>
  `).join('');
}

// ═══ TOAST ═══════════════════════════════════════════════════════════
function toast(msg){
  const el=document.getElementById('toast');
  document.getElementById('toast-msg').textContent=msg;
  el.classList.add('show');
  setTimeout(()=>el.classList.remove('show'),3200);
}

// ═══ SPIN KEYFRAME ════════════════════════════════════════════════════
const styleEl=document.createElement('style');
styleEl.textContent='@keyframes spin{to{transform:rotate(360deg)}}';
document.head.appendChild(styleEl);

// ═══ INIT ════════════════════════════════════════════════════════════
initTestimonials();
initMissions();
renderTalents();
</script>

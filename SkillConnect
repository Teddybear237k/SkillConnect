            <div class="form-group full">
              <label class="form-label">Numéro Mobile Money <sup>*</sup></label>
              <input type="tel" class="form-input" placeholder="6XX XXX XXX" id="fPhone"/>
            </div>
            <div class="form-group full">
              <label class="form-label">Réseau Mobile Money <sup>*</sup></label>
              <select class="form-select form-input" id="fMM">
                <option>MTN MoMo</option><option>Orange Money</option>
